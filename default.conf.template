server {
    listen       80;
    listen  [::]:80;

    location / {
        root   /usr/share/nginx/html;
        index  index.html index.htm;
	    try_files  $uri $uri/ /index.html;
    }

    location /schema-data/ {
        root /usr/share/nginx;
        add_header Cache-Control "no-cache";

        # Escrita via WebDAV para o botao "Publish to Live" (PUT do JSON).
        # A autenticacao fica no proxy reverso a frente desta instancia.
        # Requer o volume montado como leitura-ESCRITA (sem :ro) e gravavel
        # pelo worker do nginx (uid 101) — o entrypoint faz o chown.
        # O nginx copia entre filesystems (EXDEV) sozinho, entao nao ha
        # necessidade de client_body_temp_path dentro do volume.
        # Apenas PUT: o app so publica; remocao de schema e feita no host.
        dav_methods PUT;
        create_full_put_path on;
        dav_access user:rw group:rw all:r;
        client_max_body_size 20m;
    }

    location /config.js {
        default_type application/javascript;
        return 200 "window.env = {
            OPENAI_API_KEY: \"$OPENAI_API_KEY\",
            OPENAI_API_ENDPOINT: \"$OPENAI_API_ENDPOINT\",
            LLM_MODEL_NAME: \"$LLM_MODEL_NAME\",
            HIDE_CHARTDB_CLOUD: \"$HIDE_CHARTDB_CLOUD\",
            DISABLE_ANALYTICS: \"$DISABLE_ANALYTICS\"
        };";
    }

    error_page   500 502 503 504  /50x.html;
    location = /50x.html {
        root   /usr/share/nginx/html;
    }
}
